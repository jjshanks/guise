# Build output
/guise.exe
*.exe
*.exe~
*.dll
*.so
*.dylib

# The resource .syso IS committed so `go build` is turnkey (it carries the
# manifest walk needs at runtime); regenerate it with `go generate`.
# Any OTHER generated .syso files should not be committed.

# Test binaries and coverage
*.test
*.out
coverage.*

# Go workspace files
go.work
go.work.sum

# Vendored dependencies (we rely on the module cache, not vendoring)
/vendor/

# Profiling / debug artifacts
*.prof
*.pprof
__debug_bin*

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Claude Code worktrees / session state
.claude/
